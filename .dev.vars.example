# Copy to .dev.vars for local development.
# In production (deployed via Clawnify) these are injected automatically
# from your org's API keys / environment variables — see README.

# Required: send newsletters via Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Required for AI generation (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx

# Optional: override the generation model (default: anthropic/claude-sonnet-4)
# NEWSLETTER_MODEL=anthropic/claude-sonnet-4
